# Vite exposes only variables prefixed with VITE_.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key from Project Settings → API (legacy "anon" key also works).
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# Optional: falls back to leaderboard_team_members
VITE_SUPABASE_TEAM_TABLE=leaderboard_team_members
