# Vite exposes only variables prefixed with VITE_.
# Community copy defaults match https://digitaldreamersden.in/ and #events (see site for latest).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key from Project Settings → API (legacy anon key also works).
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# Optional: falls back to leaderboard_team_members
VITE_SUPABASE_TEAM_TABLE=leaderboard_team_members

# Brand (Digital Dreamers Den)
VITE_COMMUNITY_NAME=Digital Dreamers Den
VITE_COMMUNITY_ABBREV=D3
# Homepage hero lines
VITE_BRAND_TAGLINE=BUILDING THE FUTURE
VITE_BRAND_HEADLINE=Dream. Build. Grow.
# This page ("About this event" + welcome + intro)
VITE_EVENT_ABOUT_HEADING=About this event
VITE_EVENT_TITLE=Welcome to the activity
VITE_EVENT_INTRO=All you need from this page is your team name. Use the email you registered with—we show the name only, no roster and no extra details.
# Shown in the success dialog (leave empty to use icon only if emoji fonts fail on a device)
VITE_SUCCESS_EMOJI=🎉
# Links (footer)
VITE_COMMUNITY_SITE_URL=https://digitaldreamersden.in/
VITE_COMMUNITY_EVENTS_URL=https://digitaldreamersden.in/#events
VITE_SUPPORT_EMAIL=d3communityofficial@gmail.com
# Logo under team-lookup/public/ (copied from community site); override if hosted elsewhere.
VITE_BRAND_LOGO_SRC=/logo.png
